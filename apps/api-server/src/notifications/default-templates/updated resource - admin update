<!-- template: updated resource - admin update -->
<subject>Resource bijgewerkt op {{ project.title }}</subject>
<body>
  <mjml>
    <mj-body>
      <mj-raw>
        <!-- Mail context -->
      </mj-raw>
      <mj-section>
        <mj-column width="500px">
          <mj-text font-size="20px" font-family="Helvetica Neue">
            Er is een resource bijgewerkt.
          </mj-text>
          <mj-text>Beste administrator,</mj-text>
          <mj-text color="#525252">
            Er is recentelijk een bestaande resource aangepast. Hieronder kunt
            u direct de resource bekijken in het admin-paneel.
          </mj-text>
          <mj-button background-color="#12B886" href="{{ adminResourceUrl or redirectUrl }}">
            Weergeven
          </mj-button>
        </mj-column>
      </mj-section>
      <mj-raw>
        <!-- ALternate link -->
      </mj-raw>
      <mj-section>
        <mj-column width="400px">
          <mj-text>Of gebruik deze link in je browser:</mj-text>
        </mj-column>
        <mj-column>
          <mj-text>{{ adminResourceUrl or redirectUrl }}</mj-text>
        </mj-column>
      </mj-section>
    </mj-body>
  </mjml>
</body>
