legacy-peer-deps=true
# npm 12 defaults allow-git to "none"; "root" permits git deps from our own workspace package.json files (e.g. image-steam).
allow-git=root
# npm 12 blocks dependency install scripts by default (allowScripts allowlist). Native
# builds (sharp, sqlite3, bcrypt, ...) need them; run all scripts like npm 11 did.
# safe-chain still scans every package for malware, so supply-chain protection remains.
dangerously-allow-all-scripts=true
